{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenSplit",
  "version": "26.5.20",
  "identifier": "ai.opensplit.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenSplit",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#0e0e10",
        "additionalBrowserArgs": "--disable-gpu --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Terminal harness with right-click splits.",
    "longDescription": "OpenSplit is a fast cross-platform terminal harness for launching CLI tools like opencode, codex, claude, aider, or any shell, with right-click horizontal/vertical splits, drag-to-resize, and SSH session inheritance."
  }
}
