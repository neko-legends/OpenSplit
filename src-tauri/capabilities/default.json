{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the OpenSplit main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:webview:default",
    "core:app:default",
    "os:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "window-state:default"
  ]
}
